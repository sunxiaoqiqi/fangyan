<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <!-- 顶部功能栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="@android:color/darker_gray">

        <!-- 中英文切换 -->
        <Button
            android:id="@+id/btn_lang_toggle"
            android:layout_width="60dp"
            android:layout_height="36dp"
            android:text="中/英"
            android:textSize="12sp"
            android:backgroundTint="@android:color/holo_orange_light"
            android:layout_marginRight="4dp" />

        <!-- 语音输入按钮 -->
        <Button
            android:id="@+id/btn_voice_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🎤 语音"
            android:textSize="12sp"
            android:backgroundTint="@android:color/holo_blue_bright"
            android:layout_marginRight="4dp" />

        <!-- 切换到纯键盘模式 -->
        <Button
            android:id="@+id/btn_keyboard_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="键盘"
            android:textSize="12sp"
            android:backgroundTint="@android:color/holo_green_light" />

    </LinearLayout>

    <!-- 候选词区域（中文输入时显示） -->
    <LinearLayout
        android:id="@+id/candidate_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#E8E8E8"
        android:padding="4dp"
        android:visibility="gone">

        <!-- 拼音显示 -->
        <TextView
            android:id="@+id/pinyin_display"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:textSize="16sp"
            android:textColor="#333333"
            android:background="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp" />

        <!-- 候选词1 -->
        <Button
            android:id="@+id/candidate_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:layout_marginHorizontal="2dp" />

        <!-- 候选词2 -->
        <Button
            android:id="@+id/candidate_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:layout_marginHorizontal="2dp" />

        <!-- 候选词3 -->
        <Button
            android:id="@+id/candidate_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:layout_marginHorizontal="2dp" />

        <!-- 候选词4 -->
        <Button
            android:id="@+id/candidate_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:layout_marginHorizontal="2dp" />

        <!-- 候选词5 -->
        <Button
            android:id="@+id/candidate_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:layout_marginHorizontal="2dp" />

        <!-- 切换候选词按钮 -->
        <Button
            android:id="@+id/btn_more_candidates"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:text="▼"
            android:textSize="14sp"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- 26键位键盘 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- 第一行：QWERTYUIOP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="3dp">

            <Button android:id="@+id/btn_q" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Q" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_w" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="W" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_e" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="E" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_r" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="R" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_t" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="T" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_y" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Y" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_u" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="U" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_i" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="I" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_o" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="O" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_p" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="P" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />

        </LinearLayout>

        <!-- 第二行：ASDFGHJKL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="3dp">

            <Button android:id="@+id/btn_a" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="A" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_s" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="S" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_d" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="D" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_f" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="F" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_g" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="G" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_h" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="H" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_j" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="J" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_k" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="K" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_l" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="L" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />

        </LinearLayout>

        <!-- 第三行：ZXCVBNM + 删除 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="3dp">

            <Button android:id="@+id/btn_shift" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1.2" android:text="⇧" android:textSize="18sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/btn_z" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Z" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_x" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="X" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_c" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="C" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_v" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="V" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_b" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="B" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_n" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="N" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_m" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="M" android:textSize="12sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingStart="0dp" android:paddingEnd="0dp" />
            <Button android:id="@+id/btn_backspace" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1.2" android:text="⌫" android:textSize="18sp" android:gravity="center" android:background="@android:color/transparent" android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" />

        </LinearLayout>

        <!-- 第四行：符号、空格、确认 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btn_symbols" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="123" android:textSize="14sp" android:gravity="center" />
            <Button android:id="@+id/btn_space" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="4" android:text="空格" android:textSize="14sp" android:gravity="center" />
            <Button android:id="@+id/btn_enter" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="换行" android:textSize="14sp" android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
